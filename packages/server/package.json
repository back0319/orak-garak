{
  "name": "@main-game/server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch ./src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=cjs --target=node22 --outfile=dist/index.cjs",
    "start": "node dist/index.cjs",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@main-game/common": "workspace:*",
    "matter-js": "^0.20.0",
    "nanoid": "^5.1.6",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@types/matter-js": "^0.20.2",
    "@types/node": "^24.10.1",
    "esbuild": "^0.27.2",
    "socket.io-client": "^4.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "4.1.10"
  }
}
